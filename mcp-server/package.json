{
  "name": "@praxis/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for the Praxis chess-coaching API. Lets an AI assistant author tactic sets, opening / game studies, list students, and assign work.",
  "private": true,
  "type": "module",
  "bin": {
    "praxis-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
